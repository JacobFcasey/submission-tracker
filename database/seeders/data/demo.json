  "support_tickets": [
    {
      "reference": "TKT-000001",
      "subject": "MetLife COJ submission rejected - 23 ID mismatches",
      "status": "in_progress",
      "priority": "high",
      "category": "verification_issue",
      "company_casey_id": "caps-co-006",
      "municipality_code": "COJ",
      "upload_reference": "SUB-2026-05-006",
      "created_by_email": "lerato@casey-demo.co.za",
      "assigned_to_email": "naledi@casey-demo.co.za",
      "messages": [
        {
          "user_email": "lerato@casey-demo.co.za",
          "body": "The MetLife COJ May submission was rejected by CAPS with 23 ID number mismatches. I've downloaded the error report and cross-checked - it looks like MetLife sent us an outdated member list. Requesting corrected data from their payroll team.",
          "is_internal": false,
          "created_at": "2026-05-04T12:00:00Z"
        },
        {
          "user_email": "naledi@casey-demo.co.za",
          "body": "Thanks Lerato. I've escalated to MetLife's regional manager. They confirmed the member file was from March instead of May. Corrected file expected by end of week.",
          "is_internal": false,
          "created_at": "2026-05-05T09:30:00Z"
        },
        {
          "user_email": "naledi@casey-demo.co.za",
          "body": "Internal note: MetLife has had recurring issues with stale member data for the past 3 months. We should flag this for the quarterly review.",
          "is_internal": true,
          "created_at": "2026-05-05T09:35:00Z"
        }
      ]
    },
    {
      "reference": "TKT-000002",
      "subject": "21st Century Funeral - workings template missing columns",
      "status": "waiting_on_company",
      "priority": "medium",
      "category": "upload_query",
      "company_casey_id": "caps-co-013",
      "municipality_code": "COT",
      "upload_reference": "SUB-2026-05-012",
      "created_by_email": "sipho@casey-demo.co.za",
      "assigned_to_email": "naledi@casey-demo.co.za",
      "messages": [
        {
          "user_email": "sipho@casey-demo.co.za",
          "body": "21st Century submitted their May workings file but it's missing the Pay Number and Premium Amount columns. CAPS rejected the entire batch. I've sent them the correct template.",
          "is_internal": false,
          "created_at": "2026-04-26T10:30:00Z"
        },
        {
          "user_email": "naledi@casey-demo.co.za",
          "body": "Confirmed - they were using an old template from 2024. I've emailed accounts@21century.co.za with the updated 2026 template and a guide. Waiting for them to resubmit.",
          "is_internal": false,
          "created_at": "2026-04-27T08:15:00Z"
        }
      ]
    },
    {
      "reference": "TKT-000003",
      "subject": "Request to extend Ekurhuleni May deadline",
      "status": "resolved",
      "priority": "low",
      "category": "deadline_query",
      "company_casey_id": null,
      "municipality_code": "EKU",
      "upload_reference": null,
      "created_by_email": "sipho@casey-demo.co.za",
      "assigned_to_email": "thabo@casey-demo.co.za",
      "messages": [
        {
          "user_email": "sipho@casey-demo.co.za",
          "body": "Absa has requested a 5-day extension for the Ekurhuleni May deadline. Their payroll system migration caused delays in generating the deduction file.",
          "is_internal": false,
          "created_at": "2026-05-01T14:00:00Z"
        },
        {
          "user_email": "thabo@casey-demo.co.za",
          "body": "Approved. I've updated the EKU May deadline to the 20th. Absa confirmed they'll submit by the 18th at the latest.",
          "is_internal": false,
          "created_at": "2026-05-02T10:00:00Z"
        }
      ]
    },
