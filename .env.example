APP_NAME=FileManagement
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=daily
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --------------------
# DATABASE (MySQL / Laragon)
# --------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=root
DB_PASSWORD=

# --------------------
# SESSION / CACHE / QUEUE
# --------------------
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=file
QUEUE_CONNECTION=sync

# --------------------
# BROADCASTING (Use database driver for simplicity)
# --------------------
BROADCAST_DRIVER=log# Change to 'database' if you want to use database broadcasting
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

# --------------------
# REDIS (optional)
# --------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --------------------
# FILES
# --------------------
FILESYSTEM_DISK=local

# --------------------
# MAIL (log only)
# --------------------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="FileManagement"

# --------------------
# AWS (unused)
# --------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="FileManagement"

CASEY_API_BASE_URL=
CASEY_API_USERNAME=MAK001
CASEY_API_PASSWORD=6261622
CASEY_API_AUTH_ENDPOINT=/casey/auth/sign-in
CASEY_API_PREMIUM_BATCH_ENDPOINT=/casey/v1/premiums/batch/detailed_info
CASEY_API_PREMIUM_BATCH_ID=5239
CASEY_API_VERIFY_SSL=true
CASEY_API_TOKEN_CACHE_TTL=50

# --------------------
# CAPS REFERENCE DATA SYNC (Layer 1)
# Pulls canonical Companies / Municipalities from CAPS into the Tracker.
# --------------------
CASEY_API_MUNICIPALITIES_ENDPOINT=/v1/admin/organization/municipalities
CASEY_API_COMPANIES_ENDPOINT=/v1/admin/organization/companies
CASEY_API_SYNC_ONLY_ACTIVE=true
# Optional fallback used when CAPS does not return a province for a municipality.
CASEY_API_SYNC_DEFAULT_PROVINCE=

# --------------------
# CAPS SINGLE SIGN-ON
# Shared HS256 secret used by CAPS to sign its JWTs
# (com.casey.supportal.jwt.token.secretkey in CAPS configuration).
# --------------------
CASEY_SSO_ENABLED=false
CASEY_JWT_SHARED_SECRET=
CASEY_JWT_LEEWAY_SECONDS=30
CASEY_SSO_AUTO_PROVISION=true
CASEY_SSO_DEFAULT_ROLE=user
CASEY_SSO_REDIRECT_ROUTE=dashboard

# Auto-redirect: when an unauthenticated visitor hits the Tracker they are
# transparently bounced to this URL. The CAPS handoff page reads its JWT from
# local storage and redirects back to /auth/casey-sso with the token attached.
# Example: https://caps.example.com/casey/auth/sso-bridge
CASEY_SSO_AUTO_REDIRECT=true
CASEY_SSO_HANDOFF_URL=
# Bridge page that clears the CAPS JWT on sign-out.
# Example: https://caps.example.com/casey/auth/sso-logout
CASEY_SSO_LOGOUT_URL=
# Cool-down after a failed SSO attempt (seconds) — prevents redirect loops.
CASEY_SSO_SKIP_SECONDS=60

# --------------------
# CAPS WEBHOOK (Layer 3 — Status Echo-back)
# Shared HMAC-SHA256 secret used by CAPS to sign webhook payloads.
# --------------------
CAPS_WEBHOOK_SECRET=
